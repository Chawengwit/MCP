# =============================================================================
# MCP Data Gateway — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your values. Never commit `.env`.

# -----------------------------------------------------------------------------
# Server config
# -----------------------------------------------------------------------------
# Path to the API config file. Override this for XDG_CONFIG_HOME, per-environment
# configs, or CI isolation. Default: config/api_configs.json
# MCP_API_CONFIG_PATH=

# -----------------------------------------------------------------------------
# Transport selection
# -----------------------------------------------------------------------------
# stdio (default) — used by Claude Desktop, Codex CLI, and other process-spawn clients.
# http            — Streamable HTTP for ChatGPT Connectors, MCP Inspector, remote clients.
# MCP_TRANSPORT=stdio

# -----------------------------------------------------------------------------
# HTTP transport (only used when MCP_TRANSPORT=http)
# -----------------------------------------------------------------------------
# Bind host. Loopback values (127.0.0.1, ::1, localhost) are allowed without a
# bearer token (dev). Any other host requires MCP_HTTP_BEARER_TOKEN below — the
# server refuses to start otherwise.
# MCP_HTTP_HOST=127.0.0.1

# Bind port for the ASGI/uvicorn server.
# MCP_HTTP_PORT=8080

# Bearer token clients must present in `Authorization: Bearer <token>`.
# Generate a strong one with: python -c "import secrets; print(secrets.token_hex(32))"
# Required for non-loopback binds; missing token + public bind = fail-loud at startup.
# MCP_HTTP_BEARER_TOKEN=

# -----------------------------------------------------------------------------
# Local HTTPS (Phase 9.6 — required by Claude Desktop's Custom Connector UI)
# -----------------------------------------------------------------------------
# Claude Desktop's "Add custom connector" dialog rejects http:// URLs even on
# loopback. Run the server over HTTPS by generating a cert that macOS trusts:
#
#   brew install mkcert
#   mkcert -install                          # one-time: installs local CA
#   mkcert 127.0.0.1 localhost               # creates 127.0.0.1+1.pem + key
#
# Then point these env vars at the generated files. Both MUST be set together
# or both unset — half-configured TLS is a footgun (uvicorn would silently
# start without TLS and Claude Desktop would fail with an opaque error).
# MCP_HTTP_TLS_CERT=/Users/<you>/Documents/MCP/127.0.0.1+1.pem
# MCP_HTTP_TLS_KEY=/Users/<you>/Documents/MCP/127.0.0.1+1-key.pem

# -----------------------------------------------------------------------------
# OAuth callback (shared by all providers)
# -----------------------------------------------------------------------------
# Use 127.0.0.1 — NOT `localhost`. Some browsers treat them as different
# origins for OAuth state tracking. The redirect URI registered with the
# OAuth provider must match this exactly.
OAUTH_REDIRECT_URI=http://127.0.0.1:8765/callback

# Port for the local OAuth callback HTTP server.
# Must match the port in OAUTH_REDIRECT_URI above.
OAUTH_CALLBACK_PORT=8765

# -----------------------------------------------------------------------------
# Per-provider OAuth credentials
# -----------------------------------------------------------------------------
# Each API in config/api_configs.json that uses auth.type="oauth2" references
# its credentials via ${VAR} placeholders — e.g. "${GITHUB_CLIENT_ID}".
# By convention: ${<API_ID_UPPER>_CLIENT_ID} and ${<API_ID_UPPER>_CLIENT_SECRET}.
#
# After populating these, run:
#   python -m scripts.oauth_login <api_id>
# to drive the browser flow once. The token is stored in the system keyring
# and auto-refreshed near expiry.
#
# Example for GitHub (api_id="github" in api_configs.json):
# GITHUB_CLIENT_ID=your_client_id_here
# GITHUB_CLIENT_SECRET=your_client_secret_here

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG | INFO | WARN | ERROR
MCP_LOG_LEVEL=INFO

# Optional path to a log file. If unset, logs go to stderr only.
# stdout is reserved for the MCP JSON-RPC protocol stream.
MCP_LOG_FILE=

# Verbose request tracing (dumps full HTTP exchanges with secrets redacted).
# Default: false
MCP_DEBUG=false

# -----------------------------------------------------------------------------
# Response handling
# -----------------------------------------------------------------------------
# Maximum bytes returned in a single tool response. Larger payloads are
# truncated and metadata indicates total size + pagination hints.
# Default: 1048576 (1 MB)
MCP_MAX_RESPONSE_BYTES=1048576

# -----------------------------------------------------------------------------
# Activity logging (operator-only — not exposed to Claude)
# -----------------------------------------------------------------------------
# Records four event categories to JSONL files split by month:
#   logs/audit/   — who/when/what (security)
#   logs/debug/   — full HTTP exchange (with redaction)
#   logs/usage/   — per-call metrics (analytics)
#   logs/insight/ — what Claude asked for (intent patterns)

# Directory where activity logs are written.
MCP_LOG_DIR=./logs

# Files older than this many days are deleted when a new monthly file is
# created. The current month's file is never deleted.
MCP_LOG_RETENTION_DAYS=365

# Per-category enable flags (default: true). Set to false to disable a category.
MCP_LOG_AUDIT_ENABLED=true
MCP_LOG_DEBUG_ENABLED=true
MCP_LOG_USAGE_ENABLED=true
MCP_LOG_INSIGHT_ENABLED=true

# Async write buffering. Events are flushed every FLUSH_INTERVAL_SEC seconds
# OR when BUFFER_SIZE events accumulate, whichever comes first.
MCP_LOG_FLUSH_INTERVAL_SEC=5
MCP_LOG_BUFFER_SIZE=100

# -----------------------------------------------------------------------------
# OAuth Provider (Phase 9 — Claude.ai "Add custom connector" support)
# -----------------------------------------------------------------------------
# Setting MCP_OAUTH_ENCRYPTION_KEY turns on the OAuth Authorization Server
# surface inside the HTTP transport. Claude.ai (and any MCP client that
# speaks OAuth 2.1 + RFC 9728) can register, run the authorize-code-with-PKCE
# flow, and receive per-user access tokens.
#
# When unset, only the static MCP_HTTP_BEARER_TOKEN path is active (Phase 8
# behaviour unchanged).
#
# Generate a key once and keep it stable — rotating the key invalidates every
# stored Service API session and forces all users to re-consent.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# MCP_OAUTH_ENCRYPTION_KEY=

# Path to the OAuth Provider SQLite database. Created on first run.
# Default: data/oauth_provider.db
# MCP_OAUTH_DB_PATH=data/oauth_provider.db

# Canonical HTTPS URL of this server, as seen by the OAuth client (Claude.ai).
# RFC 8414 requires the issuer to have no query string or fragment. For local
# testing this is the ngrok URL (e.g. https://abcd.ngrok-free.app); for prod,
# the public DNS name pointed at this process.
# MCP_OAUTH_ISSUER=
