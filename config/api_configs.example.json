{
  "_comment": "Template for config/api_configs.json. Copy this file to api_configs.json and fill in real values. NEVER commit secrets — use ${ENV_VAR} placeholders and put actual values in .env. Supported auth.type values: 'oauth2' (full PKCE flow + keyring storage), 'bearer' (token from token_env), 'api_key' (key from key_env, sent in header_name), or auth=null for public APIs. The redact_fields list is per-API and is ADDITIVE on top of the global redaction list (Authorization header, access_token, password, api_key, etc. are always redacted). See README troubleshooting for first-run guidance.",
  "apis": {
    "example_rest_api": {
      "type": "rest",
      "base_url": "https://api.example.com",
      "auth": {
        "type": "oauth2",
        "provider": "generic",
        "client_id": "${EXAMPLE_REST_CLIENT_ID}",
        "client_secret": "${EXAMPLE_REST_CLIENT_SECRET}",
        "authorize_url": "https://api.example.com/oauth/authorize",
        "token_url": "https://api.example.com/oauth/token",
        "redirect_uri": "http://127.0.0.1:8765/callback",
        "scopes": ["read", "write"]
      },
      "endpoints": {
        "list_users": {
          "method": "GET",
          "path": "/v1/users",
          "query_params": ["limit", "cursor"]
        },
        "create_user": {
          "method": "POST",
          "path": "/v1/users",
          "body_schema": "UserCreate"
        }
      },
      "logging": {
        "request_payload": "metadata",
        "response_payload": "summary",
        "redact_fields": ["ssn", "credit_card", "date_of_birth"]
      },
      "limits": {
        "timeout_seconds": 30,
        "max_retries": 3
      }
    },

    "example_graphql_api": {
      "type": "graphql",
      "base_url": "https://api.example.com/graphql",
      "auth": {
        "type": "bearer",
        "token_env": "EXAMPLE_GRAPHQL_TOKEN"
      },
      "endpoints": {
        "get_viewer": {
          "operation": "query",
          "query": "query { viewer { id login } }"
        }
      },
      "logging": {
        "request_payload": "summary",
        "response_payload": "summary",
        "redact_fields": []
      },
      "limits": {
        "timeout_seconds": 30,
        "max_retries": 2
      }
    },

    "example_apikey_api": {
      "type": "rest",
      "base_url": "https://api.example.com/v2",
      "auth": {
        "type": "api_key",
        "header_name": "X-API-Key",
        "key_env": "EXAMPLE_APIKEY"
      },
      "endpoints": {
        "search": {
          "method": "GET",
          "path": "/search",
          "query_params": ["q", "page"]
        }
      },
      "logging": {
        "request_payload": "metadata",
        "response_payload": "metadata",
        "redact_fields": []
      },
      "limits": {
        "timeout_seconds": 15,
        "max_retries": 1
      }
    },

    "public_no_auth_api": {
      "_comment": "Demonstrates auth=null for public REST endpoints. fetch_data sends no Authorization header; get_status reports auth_state='not_required'.",
      "type": "rest",
      "base_url": "https://api.publicapis.example.com",
      "auth": null,
      "endpoints": {
        "list_categories": {
          "method": "GET",
          "path": "/categories"
        },
        "get_entry": {
          "method": "GET",
          "path": "/entries",
          "query_params": ["category", "limit"]
        }
      },
      "logging": {
        "request_payload": "metadata",
        "response_payload": "summary",
        "redact_fields": []
      },
      "limits": {
        "timeout_seconds": 15,
        "max_retries": 2
      }
    },

    "example_session_login_api": {
      "_comment": "Phase 9 — Service API authenticated with api_key + secret_key. Used by the OAuth Provider's /authorize/consent flow. The api_key/secret_key are supplied by the end user in the consent form; they are NEVER read from .env.",
      "type": "rest",
      "base_url": "https://service-api.example.com",
      "auth": {
        "type": "session_login",
        "login_path": "/api/v1/auth/login",
        "login_method": "POST",
        "credentials": {
          "api_key": "{api_key}",
          "secret_key": "{secret_key}"
        },
        "session_id_field": "data.session_id",
        "session_expire_field": "data.session_expire",
        "user_id_field": "data.user_id",
        "session_header": "X-Session-Id",
        "session_format": "{session_id}"
      },
      "endpoints": {
        "get_profile": {
          "method": "GET",
          "path": "/api/v1/profile"
        }
      },
      "logging": {
        "request_payload": "metadata",
        "response_payload": "summary",
        "redact_fields": ["api_key", "secret_key", "session_id"]
      },
      "limits": {
        "timeout_seconds": 15,
        "max_retries": 1
      }
    }
  }
}
