{
  "apis": {
    "github": {
      "type": "rest",
      "base_url": "https://api.github.com",
      "auth": {
        "type": "oauth2",
        "provider": "github",
        "client_id": "${GITHUB_CLIENT_ID}",
        "client_secret": "${GITHUB_CLIENT_SECRET}",
        "authorize_url": "https://github.com/login/oauth/authorize",
        "token_url": "https://github.com/login/oauth/access_token",
        "redirect_uri": "http://127.0.0.1:8765/callback",
        "scopes": ["read:user", "public_repo"]
      },
      "endpoints": {
        "get_user": {
          "method": "GET",
          "path": "/user"
        },
        "list_repos": {
          "method": "GET",
          "path": "/user/repos",
          "query_params": ["sort", "per_page"]
        }
      },
      "logging": {
        "request_payload": "metadata",
        "response_payload": "summary",
        "redact_fields": ["email", "notification_email"]
      },
      "limits": {
        "timeout_seconds": 30,
        "max_retries": 3
      }
    },
    "taximail": {
      "type": "rest",
      "base_url": "https://api.taximail.com",
      "auth": {
        "type": "session_login",
        "login_path": "/v2/user/login",
        "login_method": "POST",
        "login_content_type": "application/x-www-form-urlencoded",
        "credentials": {
          "api_key": "{api_key}",
          "secret_key": "{secret_key}"
        },
        "session_id_field": "data.session_id",
        "session_expire_field": "data.expire",
        "user_id_field": "_api_key_fingerprint",
        "session_header": "Authorization",
        "session_format": "Bearer {session_id}"
      },
      "endpoints": {
        "list_subscribers": {
          "method": "GET",
          "path": "/v2/list/35/subscribers",
          "query_params": ["display_mode", "order_by", "order_type", "page", "limit"]
        }
      },
      "logging": {
        "request_payload": "metadata",
        "response_payload": "summary",
        "redact_fields": ["email", "subscriber_email"]
      },
      "limits": {
        "timeout_seconds": 30,
        "max_retries": 3
      }
    }
  }
}
